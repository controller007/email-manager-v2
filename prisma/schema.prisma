// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  username  String?  @unique
  password  String
  firstName String?
  lastName  String?
  image     String?
  blocked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contactLists ContactList[]
  emailHistory EmailHistory[]

  @@map("users")
}

model ContactList {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  emails     String[]
  audienceId String?
  domainId   String   @db.ObjectId  // 👈 NEW: Required domain link
  createdBy  String   @db.ObjectId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  user         User           @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  domain       Domain         @relation(fields: [domainId], references: [id], onDelete: Cascade)
  emailHistory EmailHistory[]
  
  @@map("contact_lists")
}

model Domain {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  domain       String        @unique
  status       String        @default("pending")
  region       String        @default("us-east-1")
  resendId     String?       @unique
  userId       String        @db.ObjectId
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  senders      Sender[]
  contactLists ContactList[]
  
  @@map("domains")
}

model EmailHistory {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  subject        String
  body           String
  contactListId  String   @db.ObjectId
  userId         String   @db.ObjectId
  broadcastId    String?
  sentCount      Int      @default(0)
  deliveredCount Int      @default(0)
  openedCount    Int      @default(0)
  failedCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contactList     ContactList           @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipientEvents EmailRecipientEvent[]

  @@map("email_history")
}

model EmailRecipientEvent {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  emailHistoryId String       @db.ObjectId
  emailHistory   EmailHistory @relation(fields: [emailHistoryId], references: [id])
  recipientEmail String
  status         String
  createdAt      DateTime     @default(now())
}



model Sender {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String // Display name (e.g., "Jake Clever")
  email     String   @unique // Full email (e.g., "info@sender.com")
  domainId  String   @db.ObjectId
  userId    String   @db.ObjectId
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@map("senders")
}
