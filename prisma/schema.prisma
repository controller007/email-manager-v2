// schema.prisma - UPDATED
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  username  String?  @unique
  password  String
  firstName String?
  lastName  String?
  image     String?
  blocked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contactLists ContactList[]
  emailHistory EmailHistory[]

  @@map("users")
}

model ContactList {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  emails     String[]
  brevoListId Int?    // Brevo list ID
  processId   Int?    // Import process ID from Brevo
  status     String   @default("pending") // pending | ready | failed
  domainId   String   @db.ObjectId
  createdBy  String   @db.ObjectId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  user         User           @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  domain       Domain         @relation(fields: [domainId], references: [id], onDelete: Cascade)
  emailHistory EmailHistory[]
  
  @@map("contact_lists")
}

model Domain {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  domain       String        @unique
  status       String        @default("pending") // pending | verified | failed
  region       String        @default("us-east-1")
  brevoId      String?       @unique
  userId       String        @db.ObjectId
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  senders      Sender[]
  contactLists ContactList[]
  
  @@map("domains")
}

model EmailHistory {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  subject        String
  body           String
  contactListId  String   @db.ObjectId
  userId         String   @db.ObjectId
  campaignId     Int?     // Brevo campaign ID or transactional message ID
  sendMethod     String   @default("transactional") // transactional | campaign
  sentCount      Int      @default(0)
  deliveredCount Int      @default(0)
  openedCount    Int      @default(0)
  clickedCount   Int      @default(0)
  failedCount    Int      @default(0)
  bouncedCount   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contactList     ContactList           @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipientEvents EmailRecipientEvent[]

  @@map("email_history")
}

model EmailRecipientEvent {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  emailHistoryId String       @db.ObjectId
  emailHistory   EmailHistory @relation(fields: [emailHistoryId], references: [id], onDelete: Cascade)
  recipientEmail String
  status         String       // delivered | opened | clicked | bounced | failed | soft_bounce | hard_bounce
  createdAt      DateTime     @default(now())

  @@map("email_recipient_events")
}

model Sender {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  brevoId   Int?     // Brevo sender ID
  domainId  String   @db.ObjectId
  userId    String   @db.ObjectId
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@map("senders")
}